{
  "name": "@declaw/sdk",
  "version": "1.1.13",
  "description": "Secure runtime for AI agents - isolated sandboxes with network isolation, PII scanning, prompt injection defense, and egress filtering.",
  "keywords": [
    "sandbox",
    "ai-agents",
    "security",
    "firecracker",
    "microvm",
    "pii",
    "prompt-injection",
    "guardrails",
    "declaw"
  ],
  "homepage": "https://declaw.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/declaw-ai/declaw-js.git"
  },
  "bugs": "https://github.com/declaw-ai/declaw-js/issues",
  "license": "Apache-2.0",
  "author": "Declaw <hello@declaw.ai>",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "lint": "eslint src/ tests/",
    "format": "prettier --write src/ tests/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "eventsource-parser": "^3.0.0"
  },
  "optionalDependencies": {
    "undici": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "msw": "^2.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.18.1"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
